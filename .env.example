# Environment (dev or prod, default dev if not given)
ENV=dev

# Optional: Change default port
# PORT=8080

# SQLite configuration (for dev)
DB_PATH=./data/dailytracker.db

# PostgreSQL configuration (for prod)
# DB_URL=localhost:5432
# DB_USER=dailytracker
# DB_PASSWORD=your_password_here
# DB_NAME=dailytracker
